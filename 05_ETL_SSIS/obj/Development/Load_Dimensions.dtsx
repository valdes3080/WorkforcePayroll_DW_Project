          DTS:DTSID="{217aa7f9-318b-44f0-b16d-c1a750ed88a0}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Load DimPayType"
