        <SQLTask:SqlTaskData
          SQLTask:Connection="{8EFE0513-2978-4902-990F-875627D2FE63}"
          SQLTask:SqlStatementSource="UPDATE etl.ETL_RunLog&#xA;SET EndTime = GETDATE(),&#xA;    Status = 'SUCCESS',&#xA;    RowsLoaded = (&#xA;        SELECT SUM(RowsLoaded)&#xA;        FROM etl.ETL_RunLog&#xA;        WHERE PackageName IN&#xA;        (&#xA;            'Load_Staging_From_OLTP',&#xA;            'Load_Dimensions',&#xA;            'Load_FactPayroll'&#xA;        )&#xA;          AND Status = 'SUCCESS'&#xA;    ),&#xA;    ErrorMessage = NULL&#xA;WHERE RunId = (&#xA;    SELECT MAX(RunId)&#xA;    FROM etl.ETL_RunLog&#xA;    WHERE PackageName = 'Master_Load'&#xA;      AND Status = 'STARTED'&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
