      <DTS:Variables />
      <DTS:Executables>
        <DTS:Executable
          DTS:refId="Package\Sequence Container\Load DimDepartment"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{10eee763-b720-4613-b08d-f76265fe7ed3}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Load DimDepartment"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{1F31DDD1-86FD-4E89-B498-C9739DC9B172}"
              SQLTask:SqlStatementSource="&#xA;INSERT INTO dw.DimDepartment&#xA;(&#xA;    DepartmentId,&#xA;    DepartmentName,&#xA;    CostCenter,&#xA;    LocationName,&#xA;    Region&#xA;)&#xA;SELECT&#xA;    d.DepartmentId,&#xA;    d.DepartmentName,&#xA;    d.CostCenter,&#xA;    l.LocationName,&#xA;    l.Region&#xA;FROM stg.vDepartment_Clean d&#xA;LEFT JOIN stg.vLocation_Clean l&#xA;    ON d.LocationId = l.LocationId;&#xA;GO&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\Sequence Container\Load DimEmployee"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{c908d49d-e669-419e-b81e-834d22e90b20}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Load DimEmployee"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{1F31DDD1-86FD-4E89-B498-C9739DC9B172}"
              SQLTask:SqlStatementSource="INSERT INTO dw.DimEmployee&#xA;(&#xA;    EmployeeId,&#xA;    EmployeeNumber,&#xA;    FullName,&#xA;    DepartmentName,&#xA;    JobTitleName,&#xA;    PayTypeName,&#xA;    StatusName,&#xA;    ManagerName,&#xA;    BasePayRate,&#xA;    IsActive&#xA;)&#xA;SELECT&#xA;    e.EmployeeId,&#xA;    e.EmployeeNumber,&#xA;    e.FullName,&#xA;    d.DepartmentName,&#xA;    jt.JobTitleName,&#xA;    pt.PayTypeName,&#xA;    es.StatusName,&#xA;    mgr.FullName AS ManagerName,&#xA;    e.BasePayRate,&#xA;    e.IsActive&#xA;FROM stg.vEmployee_Clean e&#xA;LEFT JOIN stg.vDepartment_Clean d&#xA;    ON e.DepartmentId = d.DepartmentId&#xA;LEFT JOIN stg.vJobTitle_Clean jt&#xA;    ON e.JobTitleId = jt.JobTitleId&#xA;LEFT JOIN stg.vPayType_Clean pt&#xA;    ON e.PayTypeId = pt.PayTypeId&#xA;LEFT JOIN stg.vEmployeeStatus_Clean es&#xA;    ON e.StatusId = es.StatusId&#xA;LEFT JOIN stg.vEmployee_Clean mgr&#xA;    ON e.ManagerEmployeeId = mgr.EmployeeId;&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\Sequence Container\Load DimJobTitle"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{c7f133bd-ba3a-4adc-a428-5c70ea090455}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Load DimJobTitle"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{1F31DDD1-86FD-4E89-B498-C9739DC9B172}"
              SQLTask:SqlStatementSource="&#xA;INSERT INTO dw.DimJobTitle&#xA;(&#xA;    JobTitleId,&#xA;    JobTitleName,&#xA;    JobLevel&#xA;)&#xA;SELECT&#xA;    JobTitleId,&#xA;    JobTitleName,&#xA;    JobLevel&#xA;FROM stg.vJobTitle_Clean;&#xA;GO&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\Sequence Container\Load DimPayType"
