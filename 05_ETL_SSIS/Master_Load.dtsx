      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{8EFE0513-2978-4902-990F-875627D2FE63}"
          SQLTask:SqlStatementSource="IF NOT EXISTS (SELECT 1 FROM dw.FactPayroll)&#xA;    THROW 50100, 'Master validation failed: FactPayroll has no rows.', 1;&#xA;&#xA;IF EXISTS (&#xA;    SELECT 1&#xA;    FROM etl.ETL_RunLog&#xA;    WHERE Status = 'FAILED'&#xA;      AND StartTime &gt;= CAST(GETDATE() AS DATE)&#xA;)&#xA;    THROW 50101, 'Master validation failed: one child package failed.', 1;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
