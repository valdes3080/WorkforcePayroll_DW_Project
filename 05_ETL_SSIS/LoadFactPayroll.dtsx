  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\Load FactPayroll"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{282A69CE-0592-4649-9C63-43C4C5E453A9}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load FactPayroll"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{52D85554-B055-408E-AD81-6D1E57E2547B}"
          SQLTask:SqlStatementSource="&#xA;INSERT INTO dw.FactPayroll&#xA;(&#xA;    EmployeeKey,&#xA;    DepartmentKey,&#xA;    JobTitleKey,&#xA;    PayTypeKey,&#xA;    PayDateKey,&#xA;    RegularHours,&#xA;    OvertimeHours,&#xA;    GrossPay,&#xA;    BonusPay,&#xA;    DeductionAmount,&#xA;    NetPay&#xA;)&#xA;SELECT&#xA;    de.EmployeeKey,&#xA;    dd.DepartmentKey,&#xA;    djt.JobTitleKey,&#xA;    dpt.PayTypeKey,&#xA;    ddte.DateKey,&#xA;    p.RegularHours,&#xA;    p.OvertimeHours,&#xA;    p.GrossPay,&#xA;    p.BonusPay,&#xA;    p.DeductionAmount,&#xA;    p.NetPay&#xA;FROM stg.vPayrollTransaction_Clean p&#xA;JOIN dw.DimEmployee de&#xA;    ON p.EmployeeId = de.EmployeeId&#xA;JOIN dw.DimDepartment dd&#xA;    ON de.DepartmentName = dd.DepartmentName&#xA;JOIN dw.DimJobTitle djt&#xA;    ON de.JobTitleName = djt.JobTitleName&#xA;JOIN dw.DimPayType dpt&#xA;    ON de.PayTypeName = dpt.PayTypeName&#xA;JOIN dw.DimDate ddte&#xA;    ON p.PaymentDate = ddte.[Date];&#xA;GO&#xA;&#xA;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Log FactPayroll Success"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{BA9A5E99-7386-4046-A7E3-9A55F26933FE}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Log FactPayroll Success"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{52D85554-B055-408E-AD81-6D1E57E2547B}"
          SQLTask:SqlStatementSource="&#xA;UPDATE etl.ETL_RunLog&#xA;SET EndTime = GETDATE(),&#xA;    Status = 'SUCCESS',&#xA;    RowsLoaded = (SELECT COUNT(*) FROM dw.FactPayroll),&#xA;    ErrorMessage = NULL&#xA;WHERE RunId = (&#xA;    SELECT MAX(RunId)&#xA;    FROM etl.ETL_RunLog&#xA;    WHERE PackageName = 'Load_FactPayroll'&#xA;      AND Status = 'STARTED'&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Log Package Failure"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{953A7879-E418-49EB-BA66-9DD3FD4AB9AC}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Log Package Failure"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="1">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{52D85554-B055-408E-AD81-6D1E57E2547B}"
          SQLTask:SqlStatementSource="UPDATE etl.ETL_RunLog&#xA;SET&#xA;    EndTime = GETDATE(),&#xA;    Status = 'FAILED',&#xA;    ErrorMessage = 'Load_FactPayroll package failed.'&#xA;WHERE RunId = (&#xA;    SELECT MAX(RunId)&#xA;    FROM etl.ETL_RunLog&#xA;    WHERE PackageName = 'Load_FactPayroll'&#xA;      AND Status = 'STARTED'&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Log Package start"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{F189131C-DB6D-471B-8BC5-D317956333BE}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Log Package start"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{52D85554-B055-408E-AD81-6D1E57E2547B}"
          SQLTask:SqlStatementSource="INSERT INTO etl.ETL_RunLog&#xA;(&#xA;    PackageName,&#xA;    StartTime,&#xA;    EndTime,&#xA;    Status,&#xA;    RowsLoaded,&#xA;    ErrorMessage&#xA;)&#xA;VALUES&#xA;(&#xA;    'Load_FactPayroll',&#xA;    GETDATE(),&#xA;    GETDATE(),&#xA;    'SUCCESS',&#xA;    (SELECT COUNT(*) FROM dw.FactPayroll),&#xA;    NULL&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Truncate FactPayroll"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{F179E850-ED77-48E5-9B58-EA975BF7758A}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Truncate FactPayroll"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{52D85554-B055-408E-AD81-6D1E57E2547B}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE dw.FactPayroll;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Validate_FactPayroll"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{FC89625D-E730-4BEA-A88F-6D7D2F34F306}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Validate_FactPayroll"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{52D85554-B055-408E-AD81-6D1E57E2547B}"
          SQLTask:SqlStatementSource="IF EXISTS (&#xA;    SELECT 1&#xA;    FROM dw.FactPayroll&#xA;    WHERE EmployeeKey IS NULL&#xA;       OR DepartmentKey IS NULL&#xA;       OR JobTitleKey IS NULL&#xA;       OR PayTypeKey IS NULL&#xA;       OR PayDateKey IS NULL&#xA;)&#xA;THROW 50001, 'FactPayroll validation failed: missing dimension key.', 1;&#xA;&#xA;&#xA;&#xA;&#xA;DECLARE @stg INT, @fact INT;&#xA;&#xA;SELECT @stg = COUNT(*) FROM stg.vPayrollTransaction_Clean;&#xA;SELECT @fact = COUNT(*) FROM dw.FactPayroll;&#xA;&#xA;IF @stg &lt;&gt; @fact&#xA;THROW 50002, 'FactPayroll validation failed: row count mismatch.', 1;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM dw.FactPayroll)&#xA;THROW 50003, 'FactPayroll validation failed: no rows loaded.', 1;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
