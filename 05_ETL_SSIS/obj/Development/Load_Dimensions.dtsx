      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1F31DDD1-86FD-4E89-B498-C9739DC9B172}"
          SQLTask:SqlStatementSource="&#xA;IF NOT EXISTS (SELECT 1 FROM dw.DimDate)&#xA;    THROW 50030, 'Dimensions failed: DimDate has no rows.', 1;&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM dw.DimEmployee)&#xA;    THROW 50031, 'Dimensions failed: DimEmployee has no rows.', 1;&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM dw.DimDepartment)&#xA;    THROW 50032, 'Dimensions failed: DimDepartment has no rows.', 1;&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM dw.DimPayType)&#xA;    THROW 50033, 'Dimensions failed: DimPayType has no rows.', 1;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
