      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1F31DDD1-86FD-4E89-B498-C9739DC9B172}"
          SQLTask:SqlStatementSource="UPDATE etl.ETL_RunLog&#xA;SET&#xA;    EndTime = GETDATE(),&#xA;    Status = 'FAILED',&#xA;    ErrorMessage = 'Load_Dimensions package failed.'&#xA;WHERE RunId = (&#xA;    SELECT MAX(RunId)&#xA;    FROM etl.ETL_RunLog&#xA;    WHERE PackageName = 'Load_Dimensions'&#xA;      AND Status = 'STARTED'&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
