    <DataSet Name="ds_Pick_Department">
      <Query>
        <DataSourceName>Workforce_Payroll</DataSourceName>
        <CommandText>SELECT DISTINCT DepartmentName
FROM dw.DimDepartment
WHERE DepartmentName IS NOT NULL
ORDER BY DepartmentName;</CommandText>
      </Query>
      <Fields>
        <Field Name="DepartmentName">
          <DataField>DepartmentName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
